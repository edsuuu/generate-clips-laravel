{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "edsuuu/generate-clips-laravel",
    "type": "project",
    "description": "Template Laravel 13 com Livewire 4, Flux UI e Tailwind 4.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-mbstring": "*",
        "laravel/fortify": "^1.34",
        "laravel/framework": "^13.7",
        "laravel/sanctum": "^4.3",
        "laravel/socialite": "^5.27",
        "laravel/telescope": "^5.20",
        "laravel/tinker": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.0",
        "livewire/flux": "^2.13.1",
        "livewire/livewire": "^4.1",
        "lucascudo/laravel-pt-br-localization": "^3.0",
        "opcodesio/log-viewer": "^3.24",
        "owen-it/laravel-auditing": "*",
        "socialiteproviders/tiktok": "^5.2",
        "spatie/laravel-permission": "*"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2",
        "driftingly/rector-laravel": "^2.3",
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9.3",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            
            "pnpm install",
            "pnpm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "serve": [
            "@php artisan serve"
        ],
        "lint": [
            "pint",
            "rector process"
        ],
        "phpstan": [
            "@php -d memory_limit=2G ./vendor/bin/phpstan analyse --debug --no-progress"
        ],
        "check": [
            "@phpstan",
            "@lint",
            "@test"
        ],
        "checks": [
            "@check"
        ],
        "rector": [
            "rector process"
        ],
        "rector:check": [
            "rector process --dry-run"
        ],
        "lint:check": [
            "pint --test",
            "rector process --dry-run"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "@test"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
